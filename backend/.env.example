# =====================================================
# إعدادات التطبيق العامة
# =====================================================
APP_NAME=ServaCode API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# =====================================================
# إعدادات الأمان
# غيّر هذه القيم في الإنتاج ولا تستخدم القيم الافتراضية
# =====================================================
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_PUBLIC_FORM=5/minute
AUTO_SEED_DEMO_CONTENT=true

# =====================================================
# إعدادات قاعدة البيانات
# مثال:
# postgresql+psycopg://postgres:password@localhost:5432/company_platform
# للتطوير المحلي السريع بدون PostgreSQL:
# sqlite:///D:/platform/backend/db.sqlite3
# =====================================================
DATABASE_URL=sqlite:///D:/platform/backend/db.sqlite3

# =====================================================
# إعدادات CORS
# افصل بين الروابط بفاصلة
# =====================================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# =====================================================
# إعدادات الملفات المرفوعة
# =====================================================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# =====================================================
# إعدادات البريد - سيتم استخدامها في مراحل لاحقة
# =====================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ServaCode

# =====================================================
# إعدادات إضافية للبريد والإشعارات
# =====================================================
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10
ADMIN_NOTIFICATION_EMAIL=
ENABLE_EMAIL_NOTIFICATIONS=false

# Auto translation for Admin Panel
# Development default: mymemory (external free provider, limited usage)
# Production recommendation: libretranslate with a private/paid endpoint
AUTO_TRANSLATION_ENABLED=true
AUTO_TRANSLATION_PROVIDER=mymemory
TRANSLATION_API_URL=
TRANSLATION_API_KEY=
TRANSLATION_TIMEOUT_SECONDS=20
