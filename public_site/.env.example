NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_SITE_NAME=ServaCode
NEXT_PUBLIC_SITE_TITLE=ServaCode — Software, Web, and Tech Services
NEXT_PUBLIC_SITE_DESCRIPTION=ServaCode is a software company specialized in websites, web and desktop applications, management dashboards, ad design, and computer/technical services.
NEXT_PUBLIC_TWITTER_HANDLE=@servacode
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_DEFAULT_THEME=blue-tech
NEXT_PUBLIC_ENGLISH_ENABLED=true

# Local development only: fills empty Apps / Systems / Work pages with polished placeholder content.
# In production keep this false unless you intentionally want showcase placeholders.
NEXT_PUBLIC_SHOW_DEMO_CONTENT=false

# Keep indexing disabled locally/staging. Set true only on the final production domain.
NEXT_PUBLIC_ALLOW_INDEXING=false
